chapter "System-Initialisation"

(*
 * System Initialisation.
 *)

(* Does not build on DSpecProofs image, because it needs only one thy from DSpecProofs *)
session SysInitSpec in "spec" = SepDSpec +
  sessions
    DSpecProofs
  theories
    SysInit_SI

session SysInit = DSpecProofs +
  sessions
    SysInitSpec
  theories
    Proof_SI

session SysInitExamples in "examples" = SysInit +
  theories
    ExampleSpec_SI
    ExampleSpecIRQ_SI
